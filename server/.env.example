# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=realtymart                        # Name of the MongoDB database to use

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<long-random-hex-string>       # Generate with: openssl rand -hex 64
JWT_EXPIRES_IN=30d
REVALIDATE_SECRET=<random-hex-string>     # Must match client REVALIDATE_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourclientdomain.com # Primary allowed origin
CORS_ORIGINS=                             # Optional: comma-separated extra origins

# ── Cloudinary (image storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_EMAIL=admin@yourdomain.com
EMAIL_FROM=Your Agency <admin@yourdomain.com>

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880                     # 5 MB in bytes

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000                                 # Railway sets this automatically
